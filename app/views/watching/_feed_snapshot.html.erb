<div class="klax-spacer-md klax-feed-item">
  <div class="row">
    <div class="col-md-3">
      <p><small><%= snapshot.created_at.strftime("%A, %B %d, %Y at %H:%M") %></small></p>
    </div>
    <div class="col-md-6">
        <p class="lead">
          <%= link_to page_snapshot_path(snapshot) do %>
            <%= snapshot.page.name || truncate(snapshot.page.url) %> started being watched
          <% end %>
        </p>
    </div>
    <div class="col-md-3">
        <p><small>
          Created by <b><%= snapshot.page.user.display_name rescue '?' %></b>
        </small></p>
        <p><small>
          <%= link_to "Go to Source", snapshot.page.url %>
          &nbsp;&nbsp;&nbsp;
          <%= link_to "Edit", edit_page_path(snapshot.page) %>
        </small></p>
    </div>
  </div>
</div>
